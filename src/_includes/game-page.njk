{% extends "base.njk" %}

{% block styles %}
  .page {
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px 40px 60px;
    display: grid;
    grid-template-columns: 1fr 320px;
    grid-template-rows: auto auto auto;
    gap: 24px;
  }

  .game-title-bar {
    grid-column: 1 / -1;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .game-title-left { display: flex; flex-direction: column; gap: 10px; }

  .game-title {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(14px, 2.5vw, 24px);
    color: var(--text);
    line-height: 1.6;
    letter-spacing: 1px;
  }

  .game-meta { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }

  .tag { font-family: 'Press Start 2P', monospace; font-size: 7px; padding: 5px 9px; letter-spacing: 0.5px; }
  .tag-arcade { background: rgba(0,255,136,0.12); color: var(--accent); border: 1px solid var(--accent); }
  .tag-action { background: rgba(255,62,108,0.12); color: var(--accent2); border: 1px solid var(--accent2); }
  .tag-puzzle { background: rgba(62,184,255,0.12); color: var(--accent4); border: 1px solid var(--accent4); }
  .tag-strategy { background: rgba(255,224,51,0.12); color: var(--accent3); border: 1px solid var(--accent3); }
  .tag-platformer { background: rgba(200,100,255,0.12); color: #c864ff; border: 1px solid #c864ff; }

  .meta-stat { color: var(--muted); font-size: 19px; display: flex; align-items: center; gap: 5px; }
  .meta-stat .val { color: var(--text); }

  .game-title-right { display: flex; gap: 10px; align-items: center; flex-shrink: 0; }

  .btn-primary {
    font-family: 'Press Start 2P', monospace;
    font-size: 9px;
    background: var(--accent);
    color: var(--bg);
    border: none;
    padding: 13px 22px;
    cursor: pointer;
    letter-spacing: 1px;
    box-shadow: 4px 4px 0 #003320;
    transition: all 0.08s;
  }

  .btn-primary:hover { transform: translate(-2px,-2px); box-shadow: 6px 6px 0 #003320; }
  .btn-primary:active { transform: translate(2px,2px); box-shadow: 2px 2px 0 #003320; }

  .game-column { display: flex; flex-direction: column; gap: 20px; }

  .game-window { background: #000; border: 4px solid var(--border); position: relative; overflow: hidden; }

  .game-window-bar {
    background: var(--bg2);
    border-bottom: 2px solid var(--border);
    padding: 8px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .window-dots { display: flex; gap: 6px; }
  .dot { width: 10px; height: 10px; border-radius: 0; }
  .dot-red { background: var(--accent2); }
  .dot-yellow { background: var(--accent3); }
  .dot-green { background: var(--accent); }

  .window-title { font-family: 'Press Start 2P', monospace; font-size: 8px; color: var(--muted); letter-spacing: 1px; }

  .fullscreen-btn {
    font-family: 'Press Start 2P', monospace;
    font-size: 7px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 4px 8px;
    cursor: pointer;
    transition: all 0.1s;
  }

  .fullscreen-btn:hover { border-color: var(--accent4); color: var(--accent4); }

  .game-frame-container { position: relative; width: 100%; padding-bottom: 62.5%; background: #000; }
  .game-frame-container iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; display: block; }

  .game-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    background: {{ game.placeholderBg }};
    cursor: pointer;
    z-index: 2;
  }

  .game-placeholder.hidden { display: none; }

  .play-icon {
    width: 80px; height: 80px;
    border: 4px solid {{ game.accentColor }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    box-shadow: {{ game.pulseBoxShadow1 }};
    animation: pulse 2s ease-in-out infinite;
    transition: transform 0.1s;
  }

  .game-placeholder:hover .play-icon { transform: scale(1.1); }

  @keyframes pulse {
    0%, 100% { box-shadow: {{ game.pulseBoxShadow1 }}; }
    50% { box-shadow: {{ game.pulseBoxShadow2 }}; }
  }

  .click-to-play {
    font-family: 'Press Start 2P', monospace;
    font-size: 10px;
    color: {{ game.accentColor }};
    letter-spacing: 2px;
    animation: blink 1.2s step-end infinite;
  }

  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  .placeholder-stars { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
  .pstar { position: absolute; width: 2px; height: 2px; background: {{ game.accentColor }}; animation: twinkle 2s step-end infinite; }
  @keyframes twinkle { 0%, 100% { opacity: 0.8; } 50% { opacity: 0.1; } }

  .info-tabs { border: 2px solid var(--border); background: var(--panel); }
  .tab-bar { display: flex; border-bottom: 2px solid var(--border); }

  .tab {
    font-family: 'Press Start 2P', monospace;
    font-size: 8px;
    padding: 14px 20px;
    background: transparent;
    border: none;
    color: var(--muted);
    cursor: pointer;
    letter-spacing: 0.5px;
    border-right: 2px solid var(--border);
    transition: all 0.1s;
  }

  .tab:last-child { border-right: none; }
  .tab:hover { color: var(--text); }

  .tab.active {
    color: var(--accent);
    background: rgba(0,255,136,0.06);
    border-bottom: 2px solid var(--accent);
    margin-bottom: -2px;
  }

  .tab-content { padding: 24px; display: none; }
  .tab-content.active { display: block; }

  .desc-text { color: var(--text); font-size: 22px; line-height: 1.7; }
  .desc-text p + p { margin-top: 12px; }

  .controls-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; margin-top: 8px; }
  .control-item { background: var(--bg2); border: 1px solid var(--border); padding: 14px; display: flex; align-items: center; gap: 12px; }

  .key {
    font-family: 'Press Start 2P', monospace;
    font-size: 9px;
    background: var(--bg);
    border: 2px solid var(--border);
    border-bottom: 4px solid var(--border);
    color: var(--accent3);
    padding: 6px 10px;
    min-width: 40px;
    text-align: center;
    flex-shrink: 0;
    letter-spacing: 0.5px;
  }

  .control-label { color: var(--muted); font-size: 19px; line-height: 1.3; }

  .sidebar { display: flex; flex-direction: column; gap: 20px; }
  .sidebar-box { background: var(--panel); border: 2px solid var(--border); }

  .sidebar-header {
    font-family: 'Press Start 2P', monospace;
    font-size: 9px;
    color: var(--text);
    letter-spacing: 1px;
    padding: 14px 18px;
    border-bottom: 2px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sidebar-header span { color: var(--accent2); }

  .more-games-list { padding: 12px; display: flex; flex-direction: column; gap: 8px; }

  .more-game-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px;
    background: var(--bg2);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: all 0.1s;
    text-decoration: none;
  }

  .more-game-item:hover { border-color: var(--accent4); transform: translateX(3px); }

  .more-game-thumb {
    width: 52px; height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    border: 1px solid var(--border);
  }

  .thumb-space { background: linear-gradient(135deg, #000510, #001035); }
  .thumb-dungeon { background: linear-gradient(135deg, #1a0800, #3d1a00); }
  .thumb-platform { background: linear-gradient(135deg, #001500, #003000); }
  .thumb-fight { background: linear-gradient(135deg, #200000, #450000); }

  .more-game-info { flex: 1; min-width: 0; }
  .more-game-title { font-family: 'Press Start 2P', monospace; font-size: 8px; color: var(--text); line-height: 1.6; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; letter-spacing: 0.3px; }
  .more-game-meta { color: var(--muted); font-size: 16px; margin-top: 3px; }
  .more-game-arrow { color: var(--muted); font-size: 18px; flex-shrink: 0; }
  .more-game-item:hover .more-game-arrow { color: var(--accent4); }

  .info-list { padding: 16px 18px; display: flex; flex-direction: column; gap: 12px; }
  .info-row { display: flex; justify-content: space-between; align-items: center; padding-bottom: 10px; border-bottom: 1px solid var(--border); }
  .info-row:last-child { border-bottom: none; padding-bottom: 0; }
  .info-key { color: var(--muted); font-size: 18px; }
  .info-val { color: var(--text); font-size: 19px; text-align: right; }
  .info-val.green { color: var(--accent); }
  .info-val.yellow { color: var(--accent3); }

  @media (max-width: 900px) {
    .page { grid-template-columns: 1fr; padding: 20px; }
    .game-title-bar, .game-column, .sidebar { grid-column: 1; }
  }

  .game-window:fullscreen .game-window-bar { display: none; }
  .game-window:fullscreen .game-frame-container { padding-bottom: 0; height: 100vh; }
{% endblock %}

{% block header_center %}
  <div class="breadcrumb">
    <a href="index.html">GAMES</a>
    <span class="sep">›</span>
    <span class="current">{{ game.title }}</span>
  </div>
{% endblock %}

{% block header_right %}
  <div class="header-actions">
    <button class="btn-ghost" onclick="toggleFullscreen()">⛶ FULLSCREEN</button>
  </div>
{% endblock %}

{% block content %}
<div class="page">

  <div class="game-title-bar">
    <div class="game-title-left">
      <h1 class="game-title">{{ game.title }}</h1>
      <div class="game-meta">
        {% for tag in game.tags %}
          <span class="tag tag-{{ tag }}">{{ tag | upper }}</span>
        {% endfor %}
        <span class="meta-stat">★ <span class="val" style="color:var(--accent3)">{{ game.ratingNum }}</span>&nbsp;/ 5</span>
      </div>
    </div>
    <div class="game-title-right">
      <button class="btn-primary" onclick="startGame()">▶ PLAY NOW</button>
    </div>
  </div>

  <div class="game-column">

    <div class="game-window" id="game-window">
      <div class="game-window-bar">
        <div class="window-dots">
          <div class="dot dot-red"></div>
          <div class="dot dot-yellow"></div>
          <div class="dot dot-green"></div>
        </div>
        <span class="window-title">{{ game.windowTitle }}</span>
        <button class="fullscreen-btn" onclick="toggleFullscreen()">⛶ FULLSCREEN</button>
      </div>
      <div class="game-frame-container" id="game-frame-container">
        <div class="game-placeholder" id="game-placeholder" onclick="startGame()">
          <div class="placeholder-stars" id="placeholder-stars"></div>
          <div class="play-icon">▶</div>
          <span class="click-to-play">CLICK TO PLAY</span>
        </div>
        <iframe
          id="game-iframe"
          src="about:blank"
          allowfullscreen
          allow="autoplay; fullscreen"
          style="display:none"
        ></iframe>
      </div>
    </div>

    <div class="info-tabs">
      <div class="tab-bar">
        <button class="tab active" onclick="switchTab('desc', this)">DESCRIPTION</button>
        <button class="tab" onclick="switchTab('controls', this)">CONTROLS</button>
      </div>

      <div class="tab-content active" id="tab-desc">
        <div class="desc-text">
          {% for paragraph in game.about %}
            <p>{{ paragraph }}</p>
          {% endfor %}
        </div>
      </div>

      <div class="tab-content" id="tab-controls">
        <div class="controls-grid">
          {% for control in game.controls %}
            <div class="control-item">
              <span class="key">{{ control.key }}</span>
              <span class="control-label">{{ control.label }}</span>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

  </div>

  <div class="sidebar">

    <div class="sidebar-box">
      <div class="sidebar-header">GAME INFO</div>
      <div class="info-list">
        <div class="info-row">
          <span class="info-key">STATUS</span>
          <span class="info-val green">● ONLINE</span>
        </div>
        <div class="info-row">
          <span class="info-key">PLATFORM</span>
          <span class="info-val">BROWSER</span>
        </div>
        <div class="info-row">
          <span class="info-key">GENRE</span>
          <span class="info-val">{{ game.genre }}</span>
        </div>
        <div class="info-row">
          <span class="info-key">DIFFICULTY</span>
          <span class="info-val yellow">{{ game.difficulty }}</span>
        </div>
        <div class="info-row">
          <span class="info-key">MOBILE</span>
          <span class="info-val">{{ game.mobile }}</span>
        </div>
      </div>
    </div>

    <div class="sidebar-box">
      <div class="sidebar-header">MORE <span>GAMES</span></div>
      <div class="more-games-list">
        {% for g in games %}
          {% if g.slug !== game.slug %}
            <a class="more-game-item" href="{{ g.slug }}.html">
              <div class="more-game-thumb {{ g.thumb }}">
                {% if g.cardIconType === "image" %}
                  <img src="{{ g.cardIcon }}" alt="{{ g.title }}" style="width:100%;height:100%;object-fit:contain;">
                {% else %}
                  {{ g.sidebarIcon }}
                {% endif %}
              </div>
              <div class="more-game-info">
                <div class="more-game-title">{{ g.title }}</div>
                <div class="more-game-meta">{{ g.sidebarMeta }}</div>
              </div>
              <span class="more-game-arrow">›</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>

  </div>

</div>

<script>
  const starsEl = document.getElementById('placeholder-stars');
  for (let i = 0; i < 40; i++) {
    const s = document.createElement('div');
    s.className = 'pstar';
    s.style.left = Math.random() * 100 + '%';
    s.style.top = Math.random() * 100 + '%';
    s.style.animationDelay = Math.random() * 2 + 's';
    starsEl.appendChild(s);
  }

  function startGame() {
    const placeholder = document.getElementById('game-placeholder');
    const iframe = document.getElementById('game-iframe');
    placeholder.classList.add('hidden');
    iframe.style.display = 'block';
    iframe.src = '{{ game.iframeUrl }}';
  }

  function switchTab(id, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.getElementById('tab-' + id).classList.add('active');
    btn.classList.add('active');
  }

  function toggleFullscreen() {
    const win = document.getElementById('game-window');
    if (!document.fullscreenElement) {
      win.requestFullscreen().catch(() => {});
    } else {
      document.exitFullscreen();
    }
  }
</script>
{% endblock %}
